      { "column": "checked_naso", "label": "NASO", "position": 9, "listView": { "visible": false }, "fieldInput": { "type": "checkbox" } },
      { "column": "checked_ed_sec", "label": "ED/SEC", "position": 10, "listView": { "visible": false }, "fieldInput": { "type": "checkbox" } },
