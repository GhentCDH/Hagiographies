        "column": "heritage_institution_id",
        "label": "Heritage institution",
        "position": 2,
        "relationshipPreviewColumns": ["name"],
        "fieldInput": { "type": "recordSelect", "asArray": false }
      },
      {
        "column": "collection_place_id",
