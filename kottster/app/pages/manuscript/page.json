{
  "version": "3.4",
  "type": "table",
  "title": "Manuscripts",
  "hideInSidebar": false,
  "config": {
    "dataSource": "hagiographies_db",
    "fetchStrategy": "databaseTable",
    "table": "manuscript",
    "columns": [
